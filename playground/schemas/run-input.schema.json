{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Creem Playground Run Input",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "profile": {
            "type": [
                "string",
                "null"
            ],
            "minLength": 1
        },
        "allow_write": {
            "type": "boolean",
            "default": false
        },
        "values": {
            "type": "object",
            "default": {},
            "additionalProperties": true
        }
    }
}

{
    "name": "antoniadisio/creem-php-sdk",
    "description": "Handwritten PHP SDK for the Creem API with a stable public facade and Saloon-powered transport.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "creem",
        "sdk",
        "api",
        "payments"
    ],
    "homepage": "https://github.com/antoniadisio/creem-php-sdk",
    "support": {
        "issues": "https://github.com/antoniadisio/creem-php-sdk/issues",
        "source": "https://github.com/antoniadisio/creem-php-sdk"
    },
    "authors": [
        {
            "name": "Pantelis Antoniadis"
        }
    ],
    "require": {
        "php": "^8.4",
        "saloonphp/saloon": "^3.15"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Creem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Creem\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "test": "pest",
        "cs": "pint --test",
        "cs:fix": "pint",
        "stan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
        "qa": [
            "@rector",
            "@cs:fix",
            "@stan",
            "@test"
        ],
        "qa:check": [
            "@rector:check",
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform": {
            "php": "8.4.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

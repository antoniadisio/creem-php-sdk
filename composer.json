{
    "name": "antoniadisio/creem-php",
    "description": "Unofficial but passionate typed PHP SDK for Creem with resource DTOs, webhook helpers, and Saloon-powered transport.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "creem",
        "sdk",
        "api",
        "payments",
        "mor",
        "merchant of record"
    ],
    "homepage": "https://github.com/antoniadisio/creem-php",
    "support": {
        "issues": "https://github.com/antoniadisio/creem-php/issues",
        "security": "https://github.com/antoniadisio/creem-php/security/policy",
        "source": "https://github.com/antoniadisio/creem-php"
    },
    "authors": [
        {
            "name": "Pantelis Antoniadis"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-hash": "*",
        "ext-json": "*",
        "saloonphp/saloon": "^3.15"
    },
    "require-dev": {
        "laravel/pint": "^1.29.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Antoniadisio\\Creem\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Antoniadisio\\Creem\\Tests\\": "tests/",
            "Playground\\Support\\": "playground/Support/"
        }
    },
    "scripts": {
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "test:unit": "pest --testsuite=Unit --exclude-group=repo",
        "test:repo": "pest --testsuite=Unit --group=repo",
        "test:integration": "pest --testsuite=Integration",
        "test:local": [
            "pest --testsuite=Unit",
            "@test:integration"
        ],
        "test:smoke": "pest --testsuite=Smoke -v",
        "test": "@test:unit",
        "cs": "pint --test",
        "cs:fix": "pint",
        "stan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
        "qa": [
            "@rector",
            "@cs:fix",
            "@stan",
            "@test:local"
        ],
        "qa:check": [
            "@rector:check",
            "@cs",
            "@stan",
            "@test:local"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform": {
            "php": "8.4.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
